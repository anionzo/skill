    "url": "git+https://github.com/anionzo/skill.git"
  },
  "keywords": [
    "ai",
    "skills",
    "agent",
    "claude",
    "opencode",
    "gemini",
    "copilot",
    "coding-agent",
    "workflow"
  ],
