{
  "name": "@anionzo/skill",
  "version": "1.10.0",
  "description": "Personal AI Skill Library — vendor-neutral, multi-agent skill library for AI-powered software engineering",
  "bin": {
    "skill": "scripts/anionzo.mjs",
    "anionzo": "scripts/anionzo.mjs",
    "anionzo-skill": "scripts/anionzo.mjs"
  },
  "preferGlobal": true,
  "scripts": {
